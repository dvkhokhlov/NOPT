$PAR NUM_THREADS=4 N_MOL=1 RHF=0 CAS=1 XMC=1 D5=1 RI=1 NAME=c4h6-xmc $PAREND
#include=c4h6_pt.inp  
$RHF maxit=50 dE=1e-9 grad=1e-12 huckel $END
$CAS n_s=7 w_state=1 1 1; maxit=50 dE=1e-9 grad=1e-12 p_cutoff =0.03 $END
$XMC n_s=7 EDSHIFT=0.01 AVECOE=1 1 1; D_ONLY=0 D5=1 $END
$PROP QUAD=1 MULLIKEN=1 DISP=1 DIPOLE=1 $END
