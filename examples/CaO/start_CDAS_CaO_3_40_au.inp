$PAR NUM_THREADS=4 N_MOL=1 RHF=0 CAS=1 CDAS=1 D5=1 RI=1 NAME=CDAS_CaO_3_40_au $PAREND
#include=CDAS_CaO_3_40_au.inp 
$CAS n_s=30 w_state=ir.rep; maxit=250 dE=-1e-12 grad=1e-6 p_cutoff=0.03 $END
$RHF maxit=50 dE=1e-9 grad=1e-12 $END
$dav n_bf=2000 max_iter=500 $END
$CQD EDSHIFT=0.00 IPEA pt1_dipole=0 $END
$PROP DIPOLE=1 DISP=0 MULLIKEN=0 QUAD=0 $END
$symm group=linear $end
$W_STATE
    Lambda = 1         w_state = 1 1 1 1 1 1;     mult=1;
$END

