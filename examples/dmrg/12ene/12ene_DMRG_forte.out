set globals{
  basis               cc-pvdz
  df_basis_mp2        cc-pvdz-ri
  df_basis_scf        cc-pvdz-jkfit
  scf_type            df
  reference           rhf
  puream              false # otherwise SO2AO does not work, see PSI4 forum
  print               0
}

set forte {
# active space parameters
  frozen_docc          [24,0]
  restricted_docc      [49,0]
  active               [0,24]
# state symmetry and averaging
  avg_state            [[0,1,3]] 		# 5 states of symmetry A' (irrep = 0) and multiplicity = 1
  nstate_dressed       4
# DSRG parameters  
  correlation_solver   THREE-DSRG-MRPT2    	# DSRG theory level
  dsrg_s               0.5 				# flow parameter value
  calc_type            sa				# do SA-DSRG
  dsrg_multi_state     sa_full 			# recalculate CI after dressing of integrals
# techical parameters  
  int_type             df				# density fitted 2-e ints
  active_space_solver  sa_dmrg			# keyword to ensure that user really wants modified code 
# dmrg parameters
  dmrg_dir             TMP              # it will be translated to uppercase..
  dmrg_m               500              # DMRG MPS size
  dmrg_maxit           40               # max number of sweeps
  dmrg_mem             100               # in GB
  dmrg_scf             True
  dmrg_nthr            28
  dmrg_localize        True
  dmrg_tprop           True
}

energy('forte')


